{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://gymaxo.onrender.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://gymaxo.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://gymaxo.onrender.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://gymaxo.onrender.com"
      }
    }
  }
}
